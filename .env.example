# CubeSandbox API defaults for local development.
CUBE_API_URL=http://127.0.0.1:3000
CUBE_PROXY_NODE_IP=127.0.0.1

# Model endpoint used by Codex.
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Optional OpenAI-compatible provider aliases used by existing scripts.
CHUTES_BASE_URL=
CHUTES_API_KEY=

# Codex behavior.
SWE_INFINITE_CODEX_WIRE_API=responses
SWE_INFINITE_CODEX_REASONING_EFFORT=medium
# Optional proxy for the host Codex process. The CubeSandbox task sandbox does
# not receive the model key or proxy settings.
SWE_INFINITE_CODEX_HTTP_PROXY=

# Optional rollout-bucket metadata.
AFFINE_ROLLOUT_MINER_HOTKEY=local-cubesandbox
AFFINE_ROLLOUT_MODEL_REVISION=
AFFINE_ROLLOUT_MODEL=
AFFINE_ROLLOUT_TASK_ID=
AFFINE_ROLLOUT_VALIDATOR_HOTKEY=executor-SWE-INFINITE-local
